{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jerry102102102/Robot-Spatial-Understanding/schemas/generic-trace.v1.schema.json",
  "title": "Robot Spatial generic simulator trace v1",
  "type": "object",
  "required": ["schema_version", "run_id", "simulator", "timestep_s", "clock", "task_id", "robot", "world", "conventions", "samples"],
  "properties": {
    "schema_version": {"const": "robot-spatial-generic-trace.v1"},
    "run_id": {"type": "string", "minLength": 1},
    "simulator": {
      "type": "object",
      "required": ["name", "version"],
      "properties": {"name": {"type": "string", "minLength": 1}, "version": {"type": "string", "minLength": 1}}
    },
    "seed": {"type": ["integer", "null"]},
    "timestep_s": {"type": "number", "exclusiveMinimum": 0},
    "clock": {
      "type": "object",
      "required": ["clock_id", "domain"],
      "properties": {"clock_id": {"type": "string", "minLength": 1}, "domain": {"type": "string", "minLength": 1}}
    },
    "interval": {
      "type": "object",
      "properties": {"start_s": {"type": "number", "minimum": 0}, "end_s": {"type": "number", "minimum": 0}}
    },
    "task_id": {"type": "string", "minLength": 1},
    "intervention": {"type": "object"},
    "robot": {"type": "object"},
    "world": {"type": "object"},
    "conventions": {
      "type": "object",
      "required": ["length_unit", "angle_unit", "quaternion_order", "pose_direction"],
      "properties": {
        "length_unit": {"const": "m"},
        "angle_unit": {"const": "rad"},
        "quaternion_order": {"const": "xyzw"},
        "pose_direction": {"const": "world_from_entity"}
      }
    },
    "channel_policies": {"type": "object", "additionalProperties": {"type": "object"}},
    "samples": {
      "type": "object",
      "propertyNames": {"enum": ["joint_state", "pose", "odometry", "contact", "collision", "force_torque", "deformable"]},
      "additionalProperties": {"type": "array", "items": {"type": "object"}}
    },
    "events": {"type": "array", "items": {"type": "object"}},
    "assets": {"type": "array"}
  },
  "not": {
    "anyOf": [
      {"required": ["reward"]},
      {"required": ["success"]},
      {"required": ["is_success"]},
      {"required": ["oracle"]},
      {"required": ["evaluator"]}
    ]
  }
}
