{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jerry102102102/Robot-Spatial-Understanding/schemas/simulation-run.v1.schema.json",
  "title": "Robot Spatial simulation-run.v1 manifest",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "simulator",
    "adapter",
    "timestep_s",
    "clock",
    "interval",
    "task_id",
    "robot",
    "world",
    "conventions",
    "channels",
    "events",
    "boundaries",
    "manifest_sha256"
  ],
  "properties": {
    "schema_version": {"const": "robot-spatial-simulation-run.v1"},
    "run_id": {"type": "string", "minLength": 1},
    "simulator": {"$ref": "#/$defs/nameVersion"},
    "adapter": {
      "allOf": [{"$ref": "#/$defs/nameVersion"}],
      "properties": {"oracle_fields_accepted": {"const": false}},
      "required": ["oracle_fields_accepted"]
    },
    "seed": {"type": ["integer", "null"]},
    "timestep_s": {"type": "number", "exclusiveMinimum": 0},
    "clock": {
      "type": "object",
      "required": ["clock_id", "domain"],
      "properties": {
        "clock_id": {"type": "string", "minLength": 1},
        "domain": {"type": "string", "minLength": 1}
      }
    },
    "interval": {"$ref": "#/$defs/interval"},
    "task_id": {"type": "string", "minLength": 1},
    "intervention": {"type": "object"},
    "robot": {"type": "object"},
    "world": {"type": "object"},
    "conventions": {"$ref": "#/$defs/conventions"},
    "channels": {
      "type": "object",
      "required": ["joint_state", "pose", "odometry", "contact", "collision", "force_torque", "deformable"],
      "properties": {
        "joint_state": {"$ref": "#/$defs/channel"},
        "pose": {"$ref": "#/$defs/channel"},
        "odometry": {"$ref": "#/$defs/channel"},
        "contact": {"$ref": "#/$defs/channel"},
        "collision": {"$ref": "#/$defs/channel"},
        "force_torque": {"$ref": "#/$defs/channel"},
        "deformable": {"$ref": "#/$defs/channel"}
      },
      "additionalProperties": false
    },
    "events": {"$ref": "#/$defs/artifact"},
    "source": {"type": "object"},
    "assets": {"type": "array"},
    "boundaries": {
      "type": "object",
      "required": ["simulation_only", "official_reward_or_success_imported", "hardware_truth_established", "causation_established", "safety_established"],
      "properties": {
        "simulation_only": {"const": true},
        "official_reward_or_success_imported": {"const": false},
        "hardware_truth_established": {"const": false},
        "causation_established": {"const": false},
        "safety_established": {"const": false}
      }
    },
    "manifest_sha256": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "nameVersion": {
      "type": "object",
      "required": ["name", "version"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1}
      }
    },
    "interval": {
      "type": "object",
      "required": ["start_s", "end_s"],
      "properties": {
        "start_s": {"type": "number", "minimum": 0},
        "end_s": {"type": "number", "minimum": 0}
      }
    },
    "conventions": {
      "type": "object",
      "required": ["length_unit", "angle_unit", "quaternion_order", "pose_direction"],
      "properties": {
        "length_unit": {"const": "m"},
        "angle_unit": {"const": "rad"},
        "quaternion_order": {"const": "xyzw"},
        "pose_direction": {"const": "world_from_entity"}
      }
    },
    "artifact": {
      "type": "object",
      "required": ["path", "sha256"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "channel": {
      "oneOf": [
        {
          "type": "object",
          "required": ["status", "path", "sha256", "arrays", "max_gap_s"],
          "properties": {
            "status": {"const": "available"},
            "path": {"type": "string", "minLength": 1},
            "sha256": {"$ref": "#/$defs/sha256"},
            "arrays": {"type": "array", "items": {"type": "string"}},
            "max_gap_s": {"type": "number", "minimum": 0}
          }
        },
        {
          "type": "object",
          "required": ["status", "reason"],
          "properties": {
            "status": {"const": "unavailable"},
            "reason": {"type": "string", "minLength": 1}
          }
        }
      ]
    }
  }
}
