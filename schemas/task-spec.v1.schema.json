{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jerry102102102/Robot-Spatial-Understanding/schemas/task-spec.v1.schema.json",
  "title": "Robot Spatial task-spec.v1",
  "type": "object",
  "required": ["schema_version", "task_id", "entities", "predicates", "goal"],
  "properties": {
    "schema_version": {"const": "robot-spatial-task-spec.v1"},
    "task_id": {"type": "string", "minLength": 1},
    "entities": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {"type": "string", "minLength": 1}
    },
    "requirements": {
      "type": "object",
      "properties": {"channels": {"type": "array", "items": {"type": "string"}, "uniqueItems": true}}
    },
    "predicates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["predicate_id", "type", "parameters"],
        "properties": {
          "predicate_id": {"type": "string", "minLength": 1},
          "type": {
            "enum": [
              "joint_within_tolerance",
              "joint_position_in_range",
              "joint_velocity_below_threshold",
              "frame_within_pose_tolerance",
              "frame_position_within_tolerance",
              "base_reached_goal",
              "collision_free_over_interval",
              "path_stayed_within_corridor",
              "contact_sustained",
              "object_above_height",
              "object_follows_frame_for_duration",
              "object_inside_region",
              "object_grasped",
              "object_released_in_region",
              "inserted_to_depth",
              "deformable_keypoints_in_region",
              "deformable_shape_within_tolerance"
            ]
          },
          "parameters": {"type": "object"},
          "window": {
            "type": "object",
            "properties": {
              "start_s": {"type": "number", "minimum": 0},
              "end_s": {"type": "number", "minimum": 0}
            }
          }
        }
      }
    },
    "goal": {"$ref": "#/$defs/expression"},
    "failure": {"$ref": "#/$defs/expression"},
    "termination": {
      "type": "object",
      "properties": {"mode": {"enum": ["episode_end", "first_goal", "declared_event"]}}
    },
    "claim_boundaries": {"type": "object"}
  },
  "$defs": {
    "expression": {
      "oneOf": [
        {"type": "object", "required": ["predicate"], "properties": {"predicate": {"type": "string"}}, "additionalProperties": false},
        {"type": "object", "required": ["not"], "properties": {"not": {"$ref": "#/$defs/expression"}}, "additionalProperties": false},
        {
          "type": "object",
          "required": ["all"],
          "properties": {
            "all": {
              "type": "array",
              "minItems": 1,
              "items": {"oneOf": [{"type": "string"}, {"$ref": "#/$defs/expression"}]}
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["any"],
          "properties": {
            "any": {
              "type": "array",
              "minItems": 1,
              "items": {"oneOf": [{"type": "string"}, {"$ref": "#/$defs/expression"}]}
            }
          },
          "additionalProperties": false
        }
      ]
    }
  }
}
