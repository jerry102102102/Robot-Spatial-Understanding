<?xml version="1.0"?>
<robot name="cross_law_urdf">
  <link name="base_link"/>
  <link name="arm_link"/>
  <link name="tool_link"/>
  <joint name="yaw_joint" type="revolute">
    <parent link="base_link"/>
    <child link="arm_link"/>
    <origin xyz="0.1 -0.2 0.4" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.2" upper="1.0" effort="10" velocity="2"/>
  </joint>
  <joint name="extension_joint" type="prismatic">
    <parent link="arm_link"/>
    <child link="tool_link"/>
    <origin xyz="0.35 0 0.05" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="0" upper="0.25" effort="20" velocity="0.5"/>
  </joint>
</robot>
